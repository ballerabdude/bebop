                    float3 physics:diagonalInertia = (0.0016074058, 0.023789065, 0.024244528)
                    float physics:mass = 1.7419928
                    quatf physics:principalAxes = (0.48332033, 0.48233598, 0.5195672, 0.51361793)

                    over "shin_right_1" (
                        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
