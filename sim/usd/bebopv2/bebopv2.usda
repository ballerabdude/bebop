        }

        over "shin_left_joint"
        {
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }

        over "foot_right_joint"
        {
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }

        over "foot_left_joint"
        {
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }
    }

    over "Geometry"
    {
        over "base_link"
        {
            string isaac:nameOverride (
                displayName = "Name Override"
            )

            over "hip_abduction_right_1"
            {
                over "femur_right_1"
                {
                    over "shin_right_1"
                    {
                        over "foot_right_1"
                        {
                        }
                    }
                }
            }

            over "hip_abduction_left_1"
            {
                string isaac:nameOverride (
                    displayName = "Name Override"
                )

                over "femur_left_1"
                {
                    over "shin_left_1"
                    {
                        over "foot_left_1"
                        {
                        }
                    }
                }
            }

            over "base_link"
            {
                token visibility = "inherited"
            }

            over "base_link_1"
            {
                token visibility = "inherited"
            }

            def IsaacImuSensor "Imu_Sensor"
            {
                int angularVelocityFilterWidth = 1
                bool enabled = 1
                int linearAccelerationFilterWidth = 1
                int orientationFilterWidth = 1
                float sensorPeriod = 0.005
                quatd xformOp:orient = (1, 0, 0, 0)
                double3 xformOp:scale = (1, 1, 1)
                double3 xformOp:translate = (0, 0, 0)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
            }
        }
    }
    variantSet "Physics" = {
        "mujoco" (
            prepend payload = @./payloads/Physics/mujoco.usda@
        ) {

