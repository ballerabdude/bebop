                            float3 physics:diagonalInertia = (0.0008919446, 0.0020723299, 0.0023467257)
                            float physics:mass = 0.64200103
                            quatf physics:principalAxes = (0.85334855, -0.5145566, -0.051467456, 0.06617266)
                        }
                    }
